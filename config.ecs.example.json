{
  "source": {
    "endpoint": "ecs.example.com:9021",
    "bucket": "my-source-bucket",
    "prefix": "",
    "access_key": "ECS_ACCESS_KEY",
    "secret_key": "ECS_SECRET_KEY",
    "region": "us-east-1",
    "use_ssl": true
  },
  "destination": {
    "type": "s3",
    "s3": {
      "endpoint": "ecs-backup.example.com:9021",
      "bucket": "my-backup-bucket",
      "prefix": "backups/",
      "access_key": "ECS_DEST_ACCESS_KEY",
      "secret_key": "ECS_DEST_SECRET_KEY",
      "region": "us-east-1",
      "use_ssl": true
    }
  },
  "options": {
    "workers": 8,
    "dry_run": false,
    "skip_existing": true,
    "log_file": "backup.log",
    "retry_attempts": 3
  }
}
