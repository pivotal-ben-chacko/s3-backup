{
  "source": {
    "endpoint": "ecs.example.com:9021",
    "bucket": "my-source-bucket",
    "prefix": "",
    "access_key": "ECS_ACCESS_KEY",
    "secret_key": "ECS_SECRET_KEY",
    "region": "us-east-1",
    "use_ssl": true
  },
  "destination": {
    "type": "local",
    "local": {
      "path": "/backups/ecs"
    }
  },
  "options": {
    "workers": 8,
    "dry_run": false,
    "skip_existing": true,
    "log_file": "backup.log",
    "retry_attempts": 3
  }
}
